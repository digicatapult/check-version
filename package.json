{
  "name": "@digicatapult/check-version",
  "version": "1.5.95",
  "description": "Asserts package version is the same or higher than latest published tag",
  "main": "dist/index.mjs",
  "type": "module",
  "scripts": {
    "depcheck": "depcheck",
    "check": "tsc",
    "build": "ncc build  --license licenses.txt ./src/main.ts && mv ./dist/index.js ./dist/index.mjs",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint .",
    "test": "NODE_OPTIONS='--no-experimental-strip-types' mocha --config mocharc.json ./src/**/__tests__/**/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digicatapult/check-version.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "semver": "^7.8.5",
    "toml": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@swc-node/register": "^1.12.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.46",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.43",
    "@types/semver": "^7.7.1",
    "@types/sinon": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vercel/ncc": "^0.44.1",
    "chai": "^6.2.2",
    "depcheck": "^1.4.7",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "mocha": "^11.7.6",
    "prettier": "^3.9.6",
    "sinon": "^22.1.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  }
}
